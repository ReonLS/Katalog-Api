{
    "swagger": "2.0",
    "info": {
        "description": "Type \"Bearer\" followed by a space and JWT Token",
        "title": "Simple Product Api Visualization",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/user/product": {
            "get": {
                "description": "Retrieve all user's product automatically by userID from context",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "Get All Product",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.UserProductResponse"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/models.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/models.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/models.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.ErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                },
                "status_code": {
                    "type": "integer"
                }
            }
        },
        "models.UserProductResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "kategori": {
                    "$ref": "#/definitions/utils.Category"
                },
                "namaprod": {
                    "type": "string"
                },
                "price": {
                    "type": "number"
                },
                "stock": {
                    "type": "integer"
                }
            }
        },
        "utils.Category": {
            "type": "string",
            "enum": [
                "Baju",
                "Aksesoris",
                "Alas Kaki",
                "Dalaman"
            ],
            "x-enum-varnames": [
                "CategoryClothes",
                "CategoryAccessory",
                "CategoryFootwear",
                "CategoryInner"
            ]
        }
    }
}